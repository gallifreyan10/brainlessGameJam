[node name="BodyLabel" type="Label" parent="CanvasLayer/HelpPanel/VBoxContainer" unique_id=1036248502]
custom_minimum_size = Vector2(500, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 12
text = "Move the claw left and right before the timer reaches zero.

When the timer reaches zero, the claw drops automatically. You can also drop early.

Each Level gives you three attempts. An attempt is spent after the claw is returned to the top.

Drop minerals into the prize chute to sell them. Sold minerals add money and increase quota progress to complete level.

Reach the quota before attempts run out to complete the level.

Between levels, you can spend money earned from the sold minerals on temporary suits or save it. Suits reset when a run fails.

Suit abilities and equipped alien abilities are coming later."
autowrap_mode = 3

